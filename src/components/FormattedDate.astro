---
import { DEFAULT_LANG, type LangCode } from '../consts';

interface Props {
	date: Date;
	lang?: LangCode;
}

const { date, lang = DEFAULT_LANG } = Astro.props;
const locale = lang === 'en' ? 'en-US' : lang;
---

<time datetime={date.toISOString()}>
	{
		date.toLocaleDateString(locale, {
			year: 'numeric',
			month: 'short',
			day: 'numeric',
		})
	}
</time>
