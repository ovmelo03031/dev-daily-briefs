---
import { Icon } from 'astro-icon/components';
import { getCollection } from 'astro:content';
import BaseHead from '../components/BaseHead.astro';
import Footer from '../components/Footer.astro';
import FormattedDate from '../components/FormattedDate.astro';
import Header from '../components/Header.astro';
import TodayHighlights from '../components/TodayHighlights.astro';
import { SITE_DESCRIPTION, SITE_TITLE, CATEGORIES, type Category } from '../consts';

const allPosts = [
	...(await getCollection('ai-coding')),
	...(await getCollection('backend-fullstack')),
	...(await getCollection('dev-news')),
].sort((a, b) => b.data.pubDate.valueOf() - a.data.pubDate.valueOf());

// Build grouped highlights for the homepage: latest brief per category that
// carries a non-empty `highlights` array. If the latest brief isn't from
// today, we still surface it with its date tag.
function isSameDay(a: Date, b: Date) {
	return (
		a.getFullYear() === b.getFullYear() &&
		a.getMonth() === b.getMonth() &&
		a.getDate() === b.getDate()
	);
}

const now = new Date();
const cats: Category[] = ['ai-coding', 'backend-fullstack', 'dev-news'];

const highlightGroups = cats
	.map((slug) => {
		const latest = allPosts.find(
			(p) => p.data.category === slug && (p.data.highlights?.length ?? 0) > 0,
		);
		if (!latest) return null;
		const cat = CATEGORIES[slug];
		return {
			slug,
			label: cat.label,
			accent: cat.accent,
			icon: cat.icon,
			briefId: latest.id,
			briefTitle: latest.data.title,
			briefPubDate: latest.data.pubDate,
			isToday: isSameDay(latest.data.pubDate, now),
			highlights: latest.data.highlights ?? [],
		};
	})
	.filter((g): g is NonNullable<typeof g> => g !== null);

const latestPosts = allPosts.slice(0, 5);
---

<!doctype html>
<html lang="en">
	<head>
		<BaseHead title={SITE_TITLE} description={SITE_DESCRIPTION} />
	</head>
	<body>
		<Header />
		<main class="mx-auto max-w-5xl px-4 py-12">
			<!-- Hero -->
			<section class="text-center mb-12">
				<h1 class="text-4xl font-bold mb-4 bg-gradient-to-r from-[var(--color-accent)] via-[var(--color-blue)] to-[var(--color-cyan)] bg-clip-text text-transparent">
					Dev Daily Briefs
				</h1>
				<p class="text-lg text-[var(--color-text-muted)] max-w-2xl mx-auto">
					Curated daily digests for senior developers. AI tools, backend, and frontend news — delivered every morning.
				</p>
			</section>

			<!-- Today's Highlights — aggregated from latest brief per category -->
			<TodayHighlights groups={highlightGroups} />

			<!-- Compact category chips -->
			<section class="mb-12">
				<div class="flex flex-wrap gap-2">
					{Object.entries(CATEGORIES).map(([slug, cat]) => (
						<a
							href={`${import.meta.env.BASE_URL}${slug}`}
							class="group inline-flex items-center gap-2 rounded-full border border-[var(--color-border)] bg-[var(--color-surface)] px-3.5 py-1.5 text-sm no-underline transition-all hover:border-[var(--color-accent)] hover:bg-[var(--color-surface-2)]"
						>
							<span
								class="inline-flex h-5 w-5 items-center justify-center"
								style={`color: ${cat.accent}`}
							>
								<Icon name={cat.icon} width={14} height={14} />
							</span>
							<span class="text-[var(--color-text)] group-hover:text-[var(--color-accent)]">
								{cat.label}
							</span>
						</a>
					))}
				</div>
			</section>

			<!-- Latest Briefs (archive entry point) -->
			<section>
				<div class="mb-4 flex items-baseline justify-between">
					<h2 class="text-xl font-bold text-[var(--color-text)]">
						<span class="lang-es">Últimos briefs</span>
						<span class="lang-en">Latest Briefs</span>
						<span class="lang-fr">Derniers briefs</span>
					</h2>
					<span class="text-xs text-[var(--color-text-muted)]">
						<span class="lang-es">Últimos 5</span>
						<span class="lang-en">Latest 5</span>
						<span class="lang-fr">5 derniers</span>
					</span>
				</div>
				<div class="space-y-2">
					{latestPosts.map((post) => {
						const cat = CATEGORIES[post.data.category as Category];
						return (
							<a
								href={`${import.meta.env.BASE_URL}${post.data.category}/${post.id}/`}
								class="group flex items-center gap-3 rounded-lg border border-[var(--color-border)] bg-[var(--color-surface)] p-3 no-underline transition-all hover:border-[var(--color-accent)] hover:bg-[var(--color-surface-2)]"
							>
								<span
									class="inline-flex h-8 w-8 shrink-0 items-center justify-center rounded-lg bg-[var(--color-surface-2)]"
									style={`color: ${cat.accent}`}
								>
									<Icon name={cat.icon} width={16} height={16} />
								</span>
								<div class="min-w-0 flex-1">
									<h3 class="text-sm font-medium text-[var(--color-text)] truncate group-hover:text-[var(--color-accent)]">
										{post.data.title}
									</h3>
									<p class="text-xs text-[var(--color-text-muted)]">
										<FormattedDate date={post.data.pubDate} />
										<span class="mx-1.5">·</span>
										<span style={`color: ${cat.accent}`}>{cat.label}</span>
									</p>
								</div>
							</a>
						);
					})}
				</div>
			</section>
		</main>
		<Footer />
	</body>
</html>
