---
import { Icon } from 'astro-icon/components';

type Props = {
	name: string;
	size?: number | string;
	class?: string;
	style?: string;
};

const { name, size = '1em', class: className, style } = Astro.props;
---

<Icon
	name={name}
	width={size}
	height={size}
	class={className}
	style={style}
	aria-hidden="true"
/>
