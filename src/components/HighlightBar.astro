---
import { Icon } from 'astro-icon/components';

type Highlight = {
	text: string;
	text_es?: string;
	text_fr?: string;
	anchor: string;
	icon?: string;
};

interface Props {
	highlights: Highlight[];
}

const { highlights } = Astro.props;
if (!highlights || highlights.length === 0) return null;
---

<section class="highlight-bar" aria-label="Today's highlights">
	<header class="highlight-bar-header">
		<span class="highlight-icon" aria-hidden="true">
			<Icon name="lucide:sparkles" width={16} height={16} />
		</span>
		<div class="highlight-heading">
			<h2 class="lang-es">Lo nuevo hoy</h2>
			<h2 class="lang-en">Today's highlights</h2>
			<h2 class="lang-fr">Points forts du jour</h2>
			<p class="highlight-sub lang-es">Click en cualquiera para ir al detalle</p>
			<p class="highlight-sub lang-en">Click any item to jump to the full section</p>
			<p class="highlight-sub lang-fr">Cliquez un élément pour aller à la section complète</p>
		</div>
	</header>

	<ul class="highlight-list">
		{highlights.map((h) => (
			<li>
				<a
					class="highlight-chip"
					href={`#${h.anchor}`}
					data-target={h.anchor}
				>
					{h.icon && (
						<span class="highlight-chip-icon" aria-hidden="true">
							<Icon name={h.icon} width={18} height={18} />
						</span>
					)}
					{(h.text_es || h.text_fr) ? (
						<>
							<span class="highlight-chip-text lang-es">{h.text_es ?? h.text}</span>
							<span class="highlight-chip-text lang-en">{h.text}</span>
							{h.text_fr && (
								<span class="highlight-chip-text lang-fr">{h.text_fr}</span>
							)}
						</>
					) : (
						<span class="highlight-chip-text">{h.text}</span>
					)}
					<Icon
						name="lucide:arrow-right"
						width={14}
						height={14}
						class="highlight-chip-arrow"
						aria-hidden="true"
					/>
				</a>
			</li>
		))}
	</ul>
</section>

<style>
	.highlight-bar {
		position: relative;
		margin: 0 0 2rem;
		padding: 1.25rem 1.5rem;
		background: linear-gradient(135deg, var(--color-surface), var(--color-surface-2));
		border: 1px solid var(--color-border);
		border-radius: 16px;
		overflow: hidden;
	}

	.highlight-bar::before {
		content: '';
		position: absolute;
		top: 0;
		left: 0;
		right: 0;
		height: 3px;
		background: linear-gradient(90deg, var(--color-accent), var(--color-cyan), var(--color-green));
		border-radius: 16px 16px 0 0;
	}

	.highlight-bar-header {
		display: flex;
		align-items: flex-start;
		gap: 0.75rem;
		margin-bottom: 1rem;
	}

	.highlight-icon {
		display: inline-flex;
		align-items: center;
		justify-content: center;
		width: 32px;
		height: 32px;
		border-radius: 8px;
		background: var(--color-accent-glow);
		color: var(--color-accent);
		flex-shrink: 0;
	}

	.highlight-heading h2 {
		font-size: 1.05rem;
		font-weight: 700;
		margin: 0;
		line-height: 1.2;
		color: var(--color-text);
	}

	.highlight-sub {
		font-size: 0.75rem;
		color: var(--color-text-muted);
		margin: 0.2rem 0 0;
	}

	.highlight-list {
		list-style: none;
		padding: 0;
		margin: 0;
		display: grid;
		grid-template-columns: 1fr;
		gap: 0.5rem;
		align-items: stretch;
	}

	.highlight-list li {
		display: flex;
	}

	@media (min-width: 640px) {
		.highlight-list {
			grid-template-columns: repeat(2, 1fr);
		}
	}

	@media (min-width: 900px) {
		.highlight-list {
			grid-template-columns: repeat(3, 1fr);
		}
	}

	.highlight-chip {
		display: flex;
		align-items: center;
		gap: 0.6rem;
		width: 100%;
		padding: 0.7rem 0.85rem;
		background: var(--color-surface);
		border: 1px solid var(--color-border);
		border-radius: 10px;
		color: var(--color-text);
		text-decoration: none;
		font-size: 0.85rem;
		line-height: 1.3;
		transition: border-color 0.15s ease, background 0.15s ease, transform 0.15s ease;
	}

	.highlight-chip:hover {
		border-color: var(--color-accent);
		background: var(--color-surface-2);
		transform: translateY(-1px);
		text-decoration: none;
	}

	.highlight-chip-icon {
		display: inline-flex;
		align-items: center;
		justify-content: center;
		width: 22px;
		height: 22px;
		flex-shrink: 0;
		color: var(--color-accent);
	}

	.highlight-chip-text {
		flex: 1;
		min-width: 0;
	}

	.highlight-chip-arrow {
		flex-shrink: 0;
		color: var(--color-text-muted);
		opacity: 0;
		transform: translateX(-4px);
		transition: all 0.15s ease;
	}

	.highlight-chip:hover .highlight-chip-arrow {
		opacity: 1;
		transform: translateX(0);
		color: var(--color-accent);
	}
</style>

<script is:inline>
	// Smart anchor scrolling: find the CURRENTLY VISIBLE target (briefs
	// embed two copies for lang toggle), scroll with sticky-header offset,
	// and play a brief highlight flash on the target for feedback. Also
	// handles DEEP LINKS from outside the brief (home page chips, shared
	// URLs with a hash) so the flash plays on arrival.
	(function () {
		var HEADER_OFFSET = 72;

		function findVisibleTarget(slug) {
			var targets = document.querySelectorAll('[data-anchor="' + slug + '"]');
			for (var i = 0; i < targets.length; i++) {
				if (targets[i].offsetParent !== null) return targets[i];
			}
			return null;
		}

		function flashAndScroll(slug, behavior) {
			var target = findVisibleTarget(slug);
			if (!target) return;
			var top = target.getBoundingClientRect().top + window.scrollY - HEADER_OFFSET;
			window.scrollTo({ top: top, behavior: behavior || 'smooth' });
			target.classList.remove('is-target-flash');
			void target.offsetWidth;
			target.classList.add('is-target-flash');
			setTimeout(function () {
				target.classList.remove('is-target-flash');
			}, 1800);
		}

		document.addEventListener('click', function (e) {
			var link = e.target && e.target.closest ? e.target.closest('a.highlight-chip[data-target]') : null;
			if (!link) return;

			var slug = link.getAttribute('data-target');
			if (!slug) return;

			e.preventDefault();
			flashAndScroll(slug, 'smooth');
			if (history.replaceState) history.replaceState(null, '', '#' + slug);
		});

		// Deep-link arrival: when landing on a brief URL that carries a hash,
		// the browser has already jumped to the anchor but the flash hasn't
		// played. We re-scroll with the sticky-header offset and trigger the
		// flash for consistent feedback with in-page clicks.
		function handleInitialHash() {
			var hash = (location.hash || '').slice(1);
			if (!hash) return;
			// Wait a frame so layout + images settle, then scroll + flash
			requestAnimationFrame(function () {
				setTimeout(function () {
					flashAndScroll(hash, 'smooth');
				}, 60);
			});
		}

		if (document.readyState === 'loading') {
			document.addEventListener('DOMContentLoaded', handleInitialHash);
		} else {
			handleInitialHash();
		}

		window.addEventListener('hashchange', function () {
			var hash = (location.hash || '').slice(1);
			if (hash) flashAndScroll(hash, 'smooth');
		});
	})();
</script>
