---
// Owns anchor scroll + flash for briefs. Rendered once by the BlogPost layout
// so it is present on EVERY brief — including briefs without a HighlightBar —
// which guarantees deep links from Topic/tag pages, home chips, and shared
// URLs scroll to the section and play the flash on arrival.
//
// Three entry points, one behavior:
//  - Highlight chip click (a.highlight-chip[data-target]) — in-page jump
//  - Deep-link arrival (URL hash on load) — from tag hubs / home / shared links
//  - hashchange — same-page hash updates
---

<script is:inline>
	(function () {
		var HEADER_OFFSET = 72;
		var FLASH_MS = 2800;
		// Upper bound for a long smooth scroll; the scrollend listener usually
		// fires the flash much earlier.
		var SCROLL_FALLBACK_MS = 900;

		function findVisibleTarget(slug) {
			// Briefs embed one copy per language; only the active one is laid out.
			var targets = document.querySelectorAll('[data-anchor="' + slug + '"]');
			for (var i = 0; i < targets.length; i++) {
				if (targets[i].offsetParent !== null) return targets[i];
			}
			return null;
		}

		function playFlash(target) {
			target.classList.remove('is-target-flash');
			void target.offsetWidth;
			target.classList.add('is-target-flash');
			setTimeout(function () {
				target.classList.remove('is-target-flash');
			}, FLASH_MS);
		}

		// Scroll smoothly to the target and start the flash only once the
		// scroll has settled, so the full animation plays in view instead of
		// burning down off-screen while the page is still moving.
		function flashAndScroll(slug) {
			var target = findVisibleTarget(slug);
			if (!target) return;
			var top = Math.max(0, target.getBoundingClientRect().top + window.scrollY - HEADER_OFFSET);

			if (Math.abs(window.scrollY - top) < 2) {
				playFlash(target);
				return;
			}

			var done = false;
			var finish = function () {
				if (done) return;
				done = true;
				window.removeEventListener('scrollend', finish);
				playFlash(target);
			};
			// scrollend is not universal (older Safari) — keep a timer fallback.
			window.addEventListener('scrollend', finish, { once: true });
			setTimeout(finish, SCROLL_FALLBACK_MS);

			window.scrollTo({ top: top, behavior: 'smooth' });
		}

		document.addEventListener('click', function (e) {
			var link = e.target && e.target.closest ? e.target.closest('a.highlight-chip[data-target]') : null;
			if (!link) return;
			var slug = link.getAttribute('data-target');
			if (!slug) return;
			e.preventDefault();
			flashAndScroll(slug);
			if (history.replaceState) history.replaceState(null, '', '#' + slug);
		});

		// Deep-link arrival: wait until the visible lang copy is laid out (the
		// copies are revealed by CSS keyed off html[data-lang]), give the layout
		// a beat to settle past reveal animations, then smooth-scroll so the
		// landing reads as guided motion instead of a hard jump.
		function handleInitialHash() {
			var hash = (location.hash || '').slice(1);
			if (!hash) return;
			var attempts = 0;
			(function attempt() {
				if (findVisibleTarget(hash)) {
					setTimeout(function () {
						flashAndScroll(hash);
					}, 150);
					return;
				}
				if (++attempts < 30) requestAnimationFrame(attempt);
			})();
		}

		if (document.readyState === 'loading') {
			document.addEventListener('DOMContentLoaded', handleInitialHash);
		} else {
			handleInitialHash();
		}

		window.addEventListener('hashchange', function () {
			var hash = (location.hash || '').slice(1);
			if (hash) flashAndScroll(hash);
		});
	})();
</script>
