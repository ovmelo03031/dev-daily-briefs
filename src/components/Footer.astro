---
import { Icon } from 'astro-icon/components';

const today = new Date();
const repoUrl = 'https://github.com/ovmelo03031/dev-daily-briefs';
---

<footer class="border-t border-[var(--color-border)] py-6 mt-16 text-sm text-[var(--color-text-muted)]">
	<div class="mx-auto max-w-5xl px-4 flex flex-col gap-4 sm:flex-row sm:items-center sm:justify-between">
		<div class="flex items-center justify-center gap-4 sm:justify-start">
			<a
				href={repoUrl}
				target="_blank"
				rel="noopener noreferrer"
				class="inline-flex items-center gap-1.5 text-[var(--color-text-muted)] hover:text-[var(--color-accent)] no-underline transition-colors"
				aria-label="GitHub repository"
			>
				<Icon name="simple-icons:github" width={16} height={16} />
				<span>GitHub</span>
			</a>
			<span aria-hidden="true" class="text-[var(--color-border)]">&middot;</span>
			<a
				href={`${repoUrl}/blob/main/LICENSE`}
				target="_blank"
				rel="noopener noreferrer"
				class="inline-flex items-center gap-1.5 text-[var(--color-text-muted)] hover:text-[var(--color-accent)] no-underline transition-colors"
			>
				<Icon name="lucide:scale" width={16} height={16} />
				<span>MIT License</span>
			</a>
		</div>
		<div class="text-center sm:text-right">
			<p>Dev Daily Briefs &mdash; Curated by AI, directed by humans.</p>
			<p class="mt-0.5">&copy; {today.getFullYear()} &middot; Powered by <a href="https://astro.build/" class="hover:text-[var(--color-accent)]">Astro</a></p>
		</div>
	</div>
</footer>
