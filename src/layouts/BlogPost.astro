---
import BaseHead from '../components/BaseHead.astro';
import CategoryIcon from '../components/CategoryIcon.astro';
import Footer from '../components/Footer.astro';
import FormattedDate from '../components/FormattedDate.astro';
import Header from '../components/Header.astro';
import HighlightBar from '../components/HighlightBar.astro';
import StructuredData from '../components/StructuredData.astro';
import { CATEGORIES, DEFAULT_LANG, SITE_TITLE, type Category, type LangCode } from '../consts';
import { getCategoryLabel } from '../utils/categoryCopy';
import { localizePath } from '../utils/i18n';
import { buildArticleSchema, buildBreadcrumbSchema, buildPersonSchema } from '../utils/schema';

type Highlight = {
	text: string;
	text_es?: string;
	text_fr?: string;
	anchor: string;
	icon?: string;
};

type Props = {
	title: string;
	description: string;
	pubDate: Date;
	category: Category;
	highlights?: Highlight[];
	lang?: LangCode;
};

const { title, description, pubDate, category, highlights, lang = DEFAULT_LANG } = Astro.props;
const cat = CATEGORIES[category];
const categoryLabel = getCategoryLabel(category, lang);
const isAiCoding = category === 'ai-coding';

const canonical = new URL(localizePath(Astro.url.pathname, lang), Astro.site);
const homePath = localizePath('/', lang);
const homeUrl = Astro.site ? new URL(homePath, Astro.site).toString() : homePath;
const categoryPath = localizePath(`/${category}/`, lang);
const categoryUrl = Astro.site ? new URL(categoryPath, Astro.site).toString() : categoryPath;

const articleSchema = buildArticleSchema(
	{ title, description, pubDate, category, url: canonical, lang },
	Astro.site,
);
const breadcrumbSchema = buildBreadcrumbSchema([
	{ name: SITE_TITLE, url: homeUrl },
	{ name: categoryLabel, url: categoryUrl },
	{ name: title, url: canonical },
]);
const authorSchema = buildPersonSchema(Astro.site);

function getProseClass() {
	if (isAiCoding) return 'prose-ai-coding';
	return 'prose-brief';
}
---

<html lang={lang} data-lang={lang}>
	<head>
		<BaseHead
			title={title}
			description={description}
			type="article"
			lang={lang}
			article={{
				publishedTime: pubDate.toISOString(),
				section: cat.label,
			}}
		/>
		<StructuredData schema={[articleSchema, breadcrumbSchema, authorSchema]} />
		<link rel="stylesheet" href={`${import.meta.env.BASE_URL}styles/ai-coding-brief.css`} />
	</head>
	<body>
		<Header />
		<main class="mx-auto max-w-5xl px-4 py-12 min-w-0 overflow-x-clip">
			<article>
				<div class="mb-8">
					<a
						href={categoryPath}
						class="inline-flex items-center gap-1.5 text-sm text-[var(--color-text-muted)] hover:text-[var(--color-accent)] no-underline mb-2"
					>
						<span>&larr;</span>
						<CategoryIcon category={category} width={14} height={14} style={`color: ${cat.accent}`} />
						<span>{categoryLabel}</span>
					</a>
					{!isAiCoding && (
						<p class="text-[var(--color-text-muted)] text-sm">
							<FormattedDate date={pubDate} lang={lang} />
						</p>
					)}
				</div>
				<div class={getProseClass()}>
					{highlights && highlights.length > 0 && <HighlightBar highlights={highlights} />}
					<slot />
				</div>
			</article>
		</main>
		<Footer />
	</body>
</html>
