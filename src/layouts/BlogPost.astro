---
import BaseHead from '../components/BaseHead.astro';
import Footer from '../components/Footer.astro';
import FormattedDate from '../components/FormattedDate.astro';
import Header from '../components/Header.astro';
import { CATEGORIES, type Category } from '../consts';

type Props = {
	title: string;
	description: string;
	pubDate: Date;
	category: Category;
};

const { title, description, pubDate, category } = Astro.props;
const cat = CATEGORIES[category];
const isAiCoding = category === 'ai-coding';

function getProseClass() {
	if (isAiCoding) return 'prose-ai-coding';
	return 'prose-brief';
}
---

<html lang="en">
	<head>
		<BaseHead title={title} description={description} />
		<link rel="stylesheet" href="/styles/ai-coding-brief.css" />
	</head>
	<body>
		<Header />
		<main class="mx-auto max-w-5xl px-4 py-12">
			<article>
				<div class="mb-8">
					<a
						href={`/${category}`}
						class="inline-flex items-center gap-1.5 text-sm text-[var(--color-text-muted)] hover:text-[var(--color-accent)] no-underline mb-2"
					>
						&larr; {cat.emoji} {cat.label}
					</a>
					{!isAiCoding && (
						<p class="text-[var(--color-text-muted)] text-sm">
							<FormattedDate date={pubDate} />
						</p>
					)}
				</div>
				<div class={getProseClass()}>
					<slot />
				</div>
			</article>
		</main>
		<Footer />
	</body>
</html>
