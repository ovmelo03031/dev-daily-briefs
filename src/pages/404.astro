---
import BaseHead from '../components/BaseHead.astro';
import CategoryIcon from '../components/CategoryIcon.astro';
import Footer from '../components/Footer.astro';
import Header from '../components/Header.astro';
import { CATEGORIES, SITE_TITLE, type Category } from '../consts';
import { getCategoryLabel } from '../utils/categoryCopy';
---

<!doctype html>
<html lang="en" data-lang="en">
	<head>
		<BaseHead
			title="Page not found"
			description={`This page does not exist on ${SITE_TITLE}. Browse the latest daily briefs instead.`}
			lang="en"
			alternates={false}
		/>
		<meta name="robots" content="noindex" />
	</head>
	<body>
		<Header />
		<main class="mx-auto max-w-5xl px-4 py-20 text-center">
			<p class="text-sm font-bold uppercase tracking-[0.18em] text-[var(--color-accent)]">404</p>
			<h1 class="mt-3 text-3xl font-bold text-[var(--color-text)]">
				<span class="lang-es">Esta página no existe</span>
				<span class="lang-en">This page doesn't exist</span>
				<span class="lang-fr">Cette page n'existe pas</span>
			</h1>
			<p class="mt-3 text-[var(--color-text-muted)]">
				<span class="lang-es">El brief que buscás se movió o nunca existió. Probá una categoría:</span>
				<span class="lang-en">The brief you're looking for moved or never existed. Try a category:</span>
				<span class="lang-fr">Le brief que vous cherchez a été déplacé ou n'a jamais existé. Essayez une catégorie :</span>
			</p>
			<div class="mt-8 flex flex-wrap justify-center gap-2">
				<a
					href={import.meta.env.BASE_URL}
					class="inline-flex items-center gap-2 rounded-full border border-[var(--color-accent)] bg-[var(--color-surface)] px-4 py-2 text-sm font-medium text-[var(--color-accent)] no-underline transition-all hover:bg-[var(--color-surface-2)]"
				>
					<span class="lang-es">Inicio</span>
					<span class="lang-en">Home</span>
					<span class="lang-fr">Accueil</span>
				</a>
				{Object.entries(CATEGORIES).map(([slug, cat]) => {
					const category = slug as Category;
					return (
						<a
							href={`${import.meta.env.BASE_URL}${slug}/`}
							class="inline-flex items-center gap-2 rounded-full border border-[var(--color-border)] bg-[var(--color-surface)] px-4 py-2 text-sm no-underline transition-all hover:border-[var(--color-accent)] hover:bg-[var(--color-surface-2)]"
						>
							<span class="inline-flex h-5 w-5 items-center justify-center" style={`color: ${cat.accent}`}>
								<CategoryIcon category={category} width={14} height={14} />
							</span>
							<span class="text-[var(--color-text)]">{getCategoryLabel(category, 'en')}</span>
						</a>
					);
				})}
			</div>
		</main>
		<Footer />
	</body>
</html>
