---
import BaseHead from '../components/BaseHead.astro';
import Footer from '../components/Footer.astro';
import FormattedDate from '../components/FormattedDate.astro';
import Header from '../components/Header.astro';
import { CATEGORIES, type Category } from '../consts';

type Props = {
	title: string;
	description: string;
	pubDate: Date;
	category: Category;
};

const { title, description, pubDate, category } = Astro.props;
const cat = CATEGORIES[category];
const isAiCoding = category === 'ai-coding';
---

<html lang="en">
	<head>
		<BaseHead title={title} description={description} />
		{isAiCoding && <link rel="stylesheet" href="/styles/ai-coding-brief.css" />}
	</head>
	<body>
		<Header />
		<main class:list={["mx-auto px-4 py-12", isAiCoding ? "max-w-5xl" : "max-w-3xl"]}>
			<article>
				<div class="mb-8">
					<a
						href={`/${category}`}
						class="inline-flex items-center gap-1.5 text-sm text-[var(--color-text-muted)] hover:text-[var(--color-accent)] no-underline mb-4"
					>
						&larr; {cat.emoji} {cat.label}
					</a>
					{!isAiCoding && (
						<>
							<h1 class="text-2xl font-bold text-[var(--color-text)] leading-tight">{title}</h1>
							<p class="text-[var(--color-text-muted)] mt-2">
								<FormattedDate date={pubDate} />
							</p>
							<hr class="border-[var(--color-border)] mt-6" />
						</>
					)}
				</div>
				<div class:list={[isAiCoding ? "prose-ai-coding" : "prose"]}>
					<slot />
				</div>
			</article>
		</main>
		<Footer />
	</body>
</html>
