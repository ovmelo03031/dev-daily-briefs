---
import BaseHead from '../components/BaseHead.astro';
import CategoryIcon from '../components/CategoryIcon.astro';
import Footer from '../components/Footer.astro';
import FormattedDate from '../components/FormattedDate.astro';
import Header from '../components/Header.astro';
import HighlightBar from '../components/HighlightBar.astro';
import StructuredData from '../components/StructuredData.astro';
import { CATEGORIES, SITE_TITLE, type Category } from '../consts';
import { buildArticleSchema, buildBreadcrumbSchema } from '../utils/schema';

type Highlight = {
	text: string;
	text_es?: string;
	text_fr?: string;
	anchor: string;
	icon?: string;
};

type Props = {
	title: string;
	description: string;
	pubDate: Date;
	category: Category;
	highlights?: Highlight[];
};

const { title, description, pubDate, category, highlights } = Astro.props;
const cat = CATEGORIES[category];
const isAiCoding = category === 'ai-coding';

const canonical = new URL(Astro.url.pathname, Astro.site);
const homeUrl = Astro.site ? Astro.site.toString() : '/';
const categoryUrl = Astro.site ? new URL(category, Astro.site).toString() : `/${category}`;

const articleSchema = buildArticleSchema(
	{ title, description, pubDate, category, url: canonical },
	Astro.site,
);
const breadcrumbSchema = buildBreadcrumbSchema([
	{ name: SITE_TITLE, url: homeUrl },
	{ name: cat.label, url: categoryUrl },
	{ name: title, url: canonical },
]);

function getProseClass() {
	if (isAiCoding) return 'prose-ai-coding';
	return 'prose-brief';
}
---

<html lang="en">
	<head>
		<BaseHead
			title={title}
			description={description}
			type="article"
			article={{
				publishedTime: pubDate.toISOString(),
				section: cat.label,
			}}
		/>
		<StructuredData schema={[articleSchema, breadcrumbSchema]} />
		<link rel="stylesheet" href={`${import.meta.env.BASE_URL}styles/ai-coding-brief.css`} />
	</head>
	<body>
		<Header />
		<main class="mx-auto max-w-5xl px-4 py-12 min-w-0 overflow-x-clip">
			<article>
				<div class="mb-8">
					<a
						href={`${import.meta.env.BASE_URL}${category}`}
						class="inline-flex items-center gap-1.5 text-sm text-[var(--color-text-muted)] hover:text-[var(--color-accent)] no-underline mb-2"
					>
						<span>&larr;</span>
						<CategoryIcon category={category} width={14} height={14} style={`color: ${cat.accent}`} />
						<span>{cat.label}</span>
					</a>
					{!isAiCoding && (
						<p class="text-[var(--color-text-muted)] text-sm">
							<FormattedDate date={pubDate} />
						</p>
					)}
				</div>
				<div class={getProseClass()}>
					{highlights && highlights.length > 0 && <HighlightBar highlights={highlights} />}
					<slot />
				</div>
			</article>
		</main>
		<Footer />
	</body>
</html>
