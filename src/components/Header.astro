---
import { SITE_TITLE, CATEGORIES } from '../consts';
import LangToggle from './LangToggle.astro';
---

<header class="sticky top-0 z-50 border-b border-[var(--color-border)] bg-[var(--color-bg)]/95 backdrop-blur-sm">
	<nav class="mx-auto flex max-w-5xl items-center justify-between px-4 py-3">
		<a href={import.meta.env.BASE_URL} class="text-lg font-bold text-[var(--color-text)] hover:text-[var(--color-accent)] no-underline">
			{SITE_TITLE}
		</a>
		<div class="flex items-center gap-1">
			{Object.entries(CATEGORIES).map(([slug, cat]) => (
				<a
					href={`${import.meta.env.BASE_URL}${slug}`}
					class="rounded-lg px-3 py-1.5 text-sm text-[var(--color-text-muted)] hover:bg-[var(--color-surface)] hover:text-[var(--color-text)] no-underline transition-colors"
				>
					<span class="hidden sm:inline">{cat.emoji}</span> {cat.label}
				</a>
			))}
			<div class="ml-2 border-l border-[var(--color-border)] pl-2">
				<LangToggle />
			</div>
		</div>
	</nav>
</header>
