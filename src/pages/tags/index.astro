---
import { getCollection } from 'astro:content';
import BaseHead from '../../components/BaseHead.astro';
import Footer from '../../components/Footer.astro';
import Header from '../../components/Header.astro';
import StructuredData from '../../components/StructuredData.astro';
import { SITE_TITLE } from '../../consts';
import { ENTITIES, extractTags } from '../../utils/entityTags';
import { buildBreadcrumbSchema } from '../../utils/schema';

const allPosts = [
	...(await getCollection('ai-coding')),
	...(await getCollection('backend-fullstack')),
	...(await getCollection('dev-news')),
	...(await getCollection('gentleman-releases')),
	...(await getCollection('ai-security')),
];

const counts = new Map<string, number>();
for (const post of allPosts) {
	for (const slug of extractTags(post.data)) {
		counts.set(slug, (counts.get(slug) ?? 0) + 1);
	}
}

const tags = ENTITIES.filter((e) => (counts.get(e.slug) ?? 0) > 0)
	.map((e) => ({ ...e, count: counts.get(e.slug)! }))
	.sort((a, b) => b.count - a.count);

const canonical = new URL(Astro.url.pathname, Astro.site);
const homeUrl = Astro.site ? Astro.site.toString() : '/';
const description = `Browse Dev Daily Briefs coverage by topic — ${tags.length} tools, models, and frameworks tracked across daily digests.`;
const breadcrumbSchema = buildBreadcrumbSchema([
	{ name: SITE_TITLE, url: homeUrl },
	{ name: 'Topics', url: canonical },
]);
---

<!doctype html>
<html lang="en" data-lang="en">
	<head>
		<BaseHead title="Topics — Browse Coverage by Tool and Framework" description={description} lang="en" alternates={false} />
		<StructuredData schema={breadcrumbSchema} />
	</head>
	<body>
		<Header />
		<main class="mx-auto w-full max-w-5xl px-4 py-12">
			<h1 class="text-3xl font-bold leading-tight text-[var(--color-text)]">Topics</h1>
			<p class="mt-2 mb-6 text-[var(--color-text-muted)]">
				Every tool, model, and framework we track — each topic lists all daily briefs covering it.
			</p>
			<div class="relative mb-6">
				<svg
					class="pointer-events-none absolute left-3 top-1/2 h-4 w-4 -translate-y-1/2 text-[var(--color-text-muted)]"
					xmlns="http://www.w3.org/2000/svg"
					viewBox="0 0 24 24"
					fill="none"
					stroke="currentColor"
					stroke-width="2"
					stroke-linecap="round"
					stroke-linejoin="round"
					aria-hidden="true"
				>
					<circle cx="11" cy="11" r="8"></circle>
					<path d="m21 21-4.3-4.3"></path>
				</svg>
				<input
					id="topic-search"
					type="search"
					autocomplete="off"
					placeholder="Filter topics…"
					aria-label="Filter topics by name"
					aria-controls="topic-list"
					class="w-full rounded-full border border-[var(--color-border)] bg-[var(--color-surface)] py-2 pl-9 pr-4 text-sm text-[var(--color-text)] outline-none transition-colors placeholder:text-[var(--color-text-muted)] focus:border-[var(--color-accent)]"
				/>
			</div>
			<p id="topic-count" class="mb-4 text-xs text-[var(--color-text-muted)]" aria-live="polite">
				{tags.length} topics
			</p>
			<div id="topic-list" class="flex flex-wrap content-start items-start gap-2">
				{tags.map((tag) => (
					<a
						href={`/tags/${tag.slug}/`}
						data-topic
						data-search={`${tag.label} ${tag.slug} ${tag.aliases.join(' ')}`.toLowerCase()}
						class="group inline-flex items-center gap-2 rounded-full border border-[var(--color-border)] bg-[var(--color-surface)] px-3.5 py-1.5 text-sm no-underline transition-all hover:border-[var(--color-accent)] hover:bg-[var(--color-surface-2)]"
					>
						<span class="text-[var(--color-text)] group-hover:text-[var(--color-accent)]">{tag.label}</span>
						<span class="text-xs text-[var(--color-text-muted)]">{tag.count}</span>
					</a>
				))}
				<p id="topic-empty" class="basis-full text-sm text-[var(--color-text-muted)]" style="display: none">
					No topics match your search.
				</p>
			</div>

			<script is:inline>
				(() => {
					const input = document.getElementById('topic-search');
					const list = document.getElementById('topic-list');
					const count = document.getElementById('topic-count');
					const empty = document.getElementById('topic-empty');
					if (!input || !list || !count || !empty) return;

					const items = Array.from(list.querySelectorAll('[data-topic]'));
					const total = items.length;

					// Reserve the full-grid height so filtering never collapses the
					// page or makes the footer jump. Measured (not hardcoded) so it
					// adapts to how many rows the pills wrap into at the current width.
					const reserve = () => {
						list.style.minHeight = '';
						list.style.minHeight = list.offsetHeight + 'px';
					};

					const filter = () => {
						const q = input.value.trim().toLowerCase();
						let shown = 0;
						for (const el of items) {
							const match = !q || (el.dataset.search || '').includes(q);
							// Inline style beats Tailwind's .hidden, which loses to the
							// pill's .inline-flex utility by source order.
							el.style.display = match ? '' : 'none';
							if (match) shown++;
						}
						count.textContent = q ? `${shown} of ${total} topics` : `${total} topics`;
						empty.style.display = shown === 0 ? '' : 'none';
						// Re-measure only when the full grid is showing (empty query).
						if (!q) reserve();
					};

					// Reserve now, then again once late layout shifts settle (web
					// fonts can rewrap the pills into a different number of rows).
					const reserveIfIdle = () => {
						if (!input.value.trim()) reserve();
					};
					reserveIfIdle();
					if (document.fonts && document.fonts.ready) document.fonts.ready.then(reserveIfIdle);
					window.addEventListener('load', reserveIfIdle, { once: true });
					input.addEventListener('input', filter);
					// Recompute the reserved height on resize when nothing is filtered,
					// since the pills rewrap into a different number of rows.
					let rAF = 0;
					window.addEventListener('resize', () => {
						cancelAnimationFrame(rAF);
						rAF = requestAnimationFrame(() => {
							if (!input.value.trim()) reserve();
						});
					});
					// Restore state if the browser repopulated the field on back-nav.
					if (input.value) filter();
				})();
			</script>
		</main>
		<Footer />
	</body>
</html>
