---
import '../styles/global.css';
import { DEFAULT_LANG, LANGUAGES, SITE_AUTHOR, SITE_TITLE, type LangCode } from '../consts';
import { getLocalizedUrl, localizePath, stripLangFromPath } from '../utils/i18n';
import { Font } from 'astro:assets';

interface ArticleMeta {
	publishedTime: string;
	modifiedTime?: string;
	author?: string;
	section?: string;
	tags?: string[];
}

interface Props {
	title: string;
	description: string;
	type?: 'website' | 'article';
	image?: string;
	article?: ArticleMeta;
	lang?: LangCode;
	alternates?: boolean;
}

const { title, description, type = 'website', image, article, lang = DEFAULT_LANG, alternates = true } = Astro.props;
// Brand every page title so search engines associate each of the daily brief
// pages with the site brand. Pages that already carry the brand are left as-is.
const pageTitle = title.includes(SITE_TITLE) ? title : `${title} | ${SITE_TITLE}`;
const canonicalURL = new URL(localizePath(Astro.url.pathname, lang), Astro.site);
const alternatePath = stripLangFromPath(Astro.url.pathname);
const ogImageURL = new URL(image ?? `${import.meta.env.BASE_URL}og-image.jpg`, Astro.site);
const ogLocale = LANGUAGES[lang].ogLocale;
---

<script is:inline define:vars={{ routeLang: lang }}>
	// Resolve initial UI language BEFORE first paint to avoid a flash of
	// the wrong locale. Localized routes win; unprefixed routes are English.
	// Writes html[data-lang="es|en|fr"]; global.css keys its lang-*
	// visibility rules off that attribute.
	(function () {
		try {
			var supported = ['es', 'en', 'fr'];
			var lang = supported.indexOf(routeLang) >= 0 ? routeLang : 'en';
			document.documentElement.setAttribute('data-lang', lang);
		} catch (e) {
			document.documentElement.setAttribute('data-lang', 'en');
		}
	})();
</script>

<meta charset="utf-8" />
<meta name="viewport" content="width=device-width,initial-scale=1" />
<meta name="theme-color" content="#0b0b10" />
<link rel="icon" type="image/png" sizes="32x32" href={`${import.meta.env.BASE_URL}favicon-32.png`} />
<link rel="icon" type="image/png" sizes="16x16" href={`${import.meta.env.BASE_URL}favicon-16.png`} />
<link rel="icon" type="image/png" sizes="192x192" href={`${import.meta.env.BASE_URL}favicon-192.png`} />
<link rel="apple-touch-icon" sizes="180x180" href={`${import.meta.env.BASE_URL}apple-touch-icon.png`} />
<link rel="sitemap" href={`${import.meta.env.BASE_URL}sitemap-index.xml`} />
<link rel="alternate" type="application/rss+xml" title={`${SITE_TITLE} — All briefs`} href={`${import.meta.env.BASE_URL}rss.xml`} />
<meta name="generator" content={Astro.generator} />

<Font cssVariable="--font-atkinson" preload />

<link rel="canonical" href={canonicalURL} />
{alternates && (
	<>
		<link rel="alternate" hreflang="en" href={getLocalizedUrl(Astro.site, alternatePath, 'en')} />
		<link rel="alternate" hreflang="es" href={getLocalizedUrl(Astro.site, alternatePath, 'es')} />
		<link rel="alternate" hreflang="fr" href={getLocalizedUrl(Astro.site, alternatePath, 'fr')} />
		<link rel="alternate" hreflang="x-default" href={getLocalizedUrl(Astro.site, alternatePath, DEFAULT_LANG)} />
	</>
)}

<title>{pageTitle}</title>
<meta name="title" content={pageTitle} />
<meta name="description" content={description} />
<meta name="author" content={SITE_AUTHOR} />
<meta name="robots" content="index,follow,max-image-preview:large" />

<meta property="og:type" content={type} />
<meta property="og:locale" content={ogLocale} />
<meta property="og:site_name" content={SITE_TITLE} />
<meta property="og:url" content={canonicalURL} />
<meta property="og:title" content={pageTitle} />
<meta property="og:description" content={description} />
<meta property="og:image" content={ogImageURL} />
{!image && (
	<>
		<meta property="og:image:width" content="1200" />
		<meta property="og:image:height" content="630" />
	</>
)}
<meta property="og:image:alt" content={`${title} — ${SITE_TITLE}`} />

{article && (
	<>
		<meta property="article:published_time" content={article.publishedTime} />
		{article.modifiedTime && <meta property="article:modified_time" content={article.modifiedTime} />}
		{article.author && <meta property="article:author" content={article.author} />}
		{article.section && <meta property="article:section" content={article.section} />}
		{article.tags && article.tags.map((tag) => <meta property="article:tag" content={tag} />)}
	</>
)}

<meta name="twitter:card" content="summary_large_image" />
<meta name="twitter:url" content={canonicalURL} />
<meta name="twitter:title" content={pageTitle} />
<meta name="twitter:description" content={description} />
<meta name="twitter:image" content={ogImageURL} />

<script is:inline>
	// Scroll reveal: toggle .is-visible on reveal-* helper classes AND on
	// brief blocks (tool-sections, stat cards, trends, model table) when
	// they cross the viewport. Runs on every page, DOM-ready.
	(function () {
		var SELECTOR = [
			'.reveal-up', '.reveal-fade', '.reveal-scale',
			'.prose-ai-coding .stat-card', '.prose-brief .stat-card',
			'.prose-ai-coding .tool-section', '.prose-brief .tool-section',
			'.prose-ai-coding .model-table-wrapper',
			'.prose-ai-coding .trends', '.prose-brief .trends',
		].join(',');

		var run = function () {
			var targets = document.querySelectorAll(SELECTOR);
			if (!targets.length) return;

			var reduced = window.matchMedia && window.matchMedia('(prefers-reduced-motion: reduce)').matches;
			if (!('IntersectionObserver' in window) || reduced) {
				targets.forEach(function (el) { el.classList.add('is-visible'); });
				return;
			}

			var io = new IntersectionObserver(function (entries) {
				entries.forEach(function (entry) {
					if (entry.isIntersecting) {
						entry.target.classList.add('is-visible');
						io.unobserve(entry.target);
					}
				});
			}, { rootMargin: '0px 0px -5% 0px', threshold: 0 });

			targets.forEach(function (el) {
				// Reveal immediately if already in view at load to avoid a
				// flash of blank space above the fold.
				var rect = el.getBoundingClientRect();
				if (rect.top < window.innerHeight * 0.9 && rect.bottom > 0) {
					el.classList.add('is-visible');
				} else {
					io.observe(el);
				}
			});
		};

		if (document.readyState === 'loading') {
			document.addEventListener('DOMContentLoaded', run);
		} else {
			run();
		}
	})();
</script>
