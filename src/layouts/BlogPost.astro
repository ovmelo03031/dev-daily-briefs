---
import type { CollectionEntry } from 'astro:content';
import BaseHead from '../components/BaseHead.astro';
import Footer from '../components/Footer.astro';
import FormattedDate from '../components/FormattedDate.astro';
import Header from '../components/Header.astro';
import { CATEGORIES, type Category } from '../consts';

type Props = {
	title: string;
	description: string;
	pubDate: Date;
	category: Category;
};

const { title, description, pubDate, category } = Astro.props;
const cat = CATEGORIES[category];
---

<html lang="en">
	<head>
		<BaseHead title={title} description={description} />
	</head>
	<body>
		<Header />
		<main class="mx-auto max-w-3xl px-4 py-12">
			<article>
				<div class="mb-8">
					<a
						href={`/${category}`}
						class="inline-flex items-center gap-1.5 text-sm text-[var(--color-text-muted)] hover:text-[var(--color-accent)] no-underline mb-4"
					>
						&larr; {cat.emoji} {cat.label}
					</a>
					<h1 class="text-2xl font-bold text-[var(--color-text)] leading-tight">{title}</h1>
					<p class="text-[var(--color-text-muted)] mt-2">
						<FormattedDate date={pubDate} />
					</p>
					<hr class="border-[var(--color-border)] mt-6" />
				</div>
				<div class="prose">
					<slot />
				</div>
			</article>
		</main>
		<Footer />
	</body>
</html>
