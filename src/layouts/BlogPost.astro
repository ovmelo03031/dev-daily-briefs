---
import BaseHead from '../components/BaseHead.astro';
import CategoryIcon from '../components/CategoryIcon.astro';
import Footer from '../components/Footer.astro';
import FormattedDate from '../components/FormattedDate.astro';
import Header from '../components/Header.astro';
import HighlightBar from '../components/HighlightBar.astro';
import StructuredData from '../components/StructuredData.astro';
import { CATEGORIES, DEFAULT_LANG, SITE_TITLE, type Category, type LangCode } from '../consts';
import { getCategoryLabel } from '../utils/categoryCopy';
import { localizePath } from '../utils/i18n';
import { buildArticleSchema, buildBreadcrumbSchema, buildPersonSchema } from '../utils/schema';

type Highlight = {
	text: string;
	text_es?: string;
	text_fr?: string;
	anchor: string;
	icon?: string;
};

type BriefNavLink = {
	slug: string;
	title: string;
};

type TagChip = {
	slug: string;
	label: string;
};

type Props = {
	title: string;
	description: string;
	pubDate: Date;
	category: Category;
	highlights?: Highlight[];
	lang?: LangCode;
	prevBrief?: BriefNavLink;
	nextBrief?: BriefNavLink;
	tags?: TagChip[];
};

const { title, description, pubDate, category, highlights, lang = DEFAULT_LANG, prevBrief, nextBrief, tags } = Astro.props;
const cat = CATEGORIES[category];
const categoryLabel = getCategoryLabel(category, lang);
const isAiCoding = category === 'ai-coding';

const canonical = new URL(localizePath(Astro.url.pathname, lang), Astro.site);
const homePath = localizePath('/', lang);
const homeUrl = Astro.site ? new URL(homePath, Astro.site).toString() : homePath;
const categoryPath = localizePath(`/${category}/`, lang);
const categoryUrl = Astro.site ? new URL(categoryPath, Astro.site).toString() : categoryPath;

const articleSchema = buildArticleSchema(
	{ title, description, pubDate, category, url: canonical, lang },
	Astro.site,
);
const breadcrumbSchema = buildBreadcrumbSchema([
	{ name: SITE_TITLE, url: homeUrl },
	{ name: categoryLabel, url: categoryUrl },
	{ name: title, url: canonical },
]);
const authorSchema = buildPersonSchema(Astro.site);

function getProseClass() {
	if (isAiCoding) return 'prose-ai-coding';
	return 'prose-brief';
}
---

<html lang={lang} data-lang={lang}>
	<head>
		<BaseHead
			title={title}
			description={description}
			type="article"
			lang={lang}
			article={{
				publishedTime: pubDate.toISOString(),
				section: cat.label,
			}}
		/>
		<StructuredData schema={[articleSchema, breadcrumbSchema, authorSchema]} />
		<link rel="stylesheet" href={`${import.meta.env.BASE_URL}styles/ai-coding-brief.css`} />
	</head>
	<body>
		<Header />
		<main class="mx-auto max-w-5xl px-4 py-12 min-w-0 overflow-x-clip">
			<article>
				<div class="mb-8">
					<a
						href={categoryPath}
						class="inline-flex items-center gap-1.5 text-sm text-[var(--color-text-muted)] hover:text-[var(--color-accent)] no-underline mb-2"
					>
						<span>&larr;</span>
						<CategoryIcon category={category} width={14} height={14} style={`color: ${cat.accent}`} />
						<span>{categoryLabel}</span>
					</a>
					<h1 class="mt-3 text-2xl font-bold leading-tight text-[var(--color-text)] sm:text-3xl">
						{title}
					</h1>
					{!isAiCoding && (
						<p class="mt-2 text-[var(--color-text-muted)] text-sm">
							<FormattedDate date={pubDate} lang={lang} />
						</p>
					)}
					{tags && tags.length > 0 && (
						<div class="mt-3 flex flex-wrap gap-1.5">
							{tags.map((tag) => (
								<a
									href={`/tags/${tag.slug}/`}
									class="inline-flex rounded-full border border-[var(--color-border)] bg-[var(--color-surface)] px-2.5 py-0.5 text-xs text-[var(--color-text-muted)] no-underline transition-all hover:border-[var(--color-accent)] hover:text-[var(--color-accent)]"
								>
									{tag.label}
								</a>
							))}
						</div>
					)}
				</div>
				<div class={getProseClass()}>
					{highlights && highlights.length > 0 && <HighlightBar highlights={highlights} />}
					<slot />
				</div>
				{(prevBrief || nextBrief) && (
					<nav aria-label="Brief navigation" class="mt-12 grid gap-3 border-t border-[var(--color-border)] pt-6 sm:grid-cols-2">
						{prevBrief ? (
							<a
								href={localizePath(`/${category}/${prevBrief.slug}/`, lang)}
								rel="prev"
								class="group rounded-lg border border-[var(--color-border)] bg-[var(--color-surface)] p-4 no-underline transition-all hover:border-[var(--color-accent)]"
							>
								<span class="text-xs text-[var(--color-text-muted)]">
									<span class="lang-es">← Brief anterior</span>
									<span class="lang-en">← Previous brief</span>
									<span class="lang-fr">← Brief précédent</span>
								</span>
								<span class="mt-1 block truncate text-sm font-medium text-[var(--color-text)] group-hover:text-[var(--color-accent)]">
									{prevBrief.title}
								</span>
							</a>
						) : (
							<span />
						)}
						{nextBrief && (
							<a
								href={localizePath(`/${category}/${nextBrief.slug}/`, lang)}
								rel="next"
								class="group rounded-lg border border-[var(--color-border)] bg-[var(--color-surface)] p-4 text-right no-underline transition-all hover:border-[var(--color-accent)]"
							>
								<span class="text-xs text-[var(--color-text-muted)]">
									<span class="lang-es">Brief siguiente →</span>
									<span class="lang-en">Next brief →</span>
									<span class="lang-fr">Brief suivant →</span>
								</span>
								<span class="mt-1 block truncate text-sm font-medium text-[var(--color-text)] group-hover:text-[var(--color-accent)]">
									{nextBrief.title}
								</span>
							</a>
						)}
					</nav>
				)}
			</article>
		</main>
		<Footer />
	</body>
</html>
