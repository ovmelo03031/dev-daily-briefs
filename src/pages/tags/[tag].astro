---
import { getCollection } from 'astro:content';
import BaseHead from '../../components/BaseHead.astro';
import CategoryIcon from '../../components/CategoryIcon.astro';
import Footer from '../../components/Footer.astro';
import FormattedDate from '../../components/FormattedDate.astro';
import Header from '../../components/Header.astro';
import StructuredData from '../../components/StructuredData.astro';
import { pickLang } from '../../components/brief/pickLang';
import { CATEGORIES, SITE_TITLE, type Category } from '../../consts';
import { getCategoryLabel } from '../../utils/categoryCopy';
import { ENTITIES, getEntity, extractTags } from '../../utils/entityTags';
import { buildBreadcrumbSchema } from '../../utils/schema';

export async function getStaticPaths() {
	const allPosts = [
		...(await getCollection('ai-coding')),
		...(await getCollection('backend-fullstack')),
		...(await getCollection('dev-news')),
		...(await getCollection('gentleman-releases')),
	].sort((a, b) => b.data.pubDate.valueOf() - a.data.pubDate.valueOf());

	const postsByTag = new Map<string, typeof allPosts>();
	for (const post of allPosts) {
		for (const slug of extractTags(post.data)) {
			const list = postsByTag.get(slug) ?? [];
			list.push(post);
			postsByTag.set(slug, list);
		}
	}

	// Only entities with coverage get a page — empty hubs are thin content.
	return ENTITIES.filter((e) => (postsByTag.get(e.slug)?.length ?? 0) > 0).map((e) => ({
		params: { tag: e.slug },
		props: { tag: e.slug, posts: postsByTag.get(e.slug)! },
	}));
}

const { tag, posts } = Astro.props;
const entity = getEntity(tag)!;
const canonical = new URL(Astro.url.pathname, Astro.site);
const homeUrl = Astro.site ? Astro.site.toString() : '/';
const tagsUrl = Astro.site ? new URL('/tags/', Astro.site).toString() : '/tags/';
const title = `${entity.label} — Daily Brief Coverage`;
const description = `Every Dev Daily Briefs digest covering ${entity.label}: ${posts.length} brief${posts.length === 1 ? '' : 's'} with releases, updates, and analysis, refreshed daily.`;
const breadcrumbSchema = buildBreadcrumbSchema([
	{ name: SITE_TITLE, url: homeUrl },
	{ name: 'Topics', url: tagsUrl },
	{ name: entity.label, url: canonical },
]);
---

<!doctype html>
<html lang="en" data-lang="en">
	<head>
		<BaseHead title={title} description={description} lang="en" alternates={false} />
		<StructuredData schema={breadcrumbSchema} />
	</head>
	<body>
		<Header />
		<main class="mx-auto max-w-5xl px-4 py-12">
			<div class="mb-8">
				<a href="/tags/" class="inline-flex items-center gap-1.5 text-sm text-[var(--color-text-muted)] hover:text-[var(--color-accent)] no-underline mb-2">
					<span>&larr;</span>
					<span>All topics</span>
				</a>
				<h1 class="mt-3 text-3xl font-bold leading-tight text-[var(--color-text)]">{entity.label}</h1>
				<p class="mt-2 text-[var(--color-text-muted)]">
					{posts.length} daily brief{posts.length === 1 ? '' : 's'} covering {entity.label}
				</p>
			</div>
			<div class="space-y-2">
				{posts.map((post) => {
					const cat = CATEGORIES[post.data.category as Category];
					return (
						<a
							href={`/${post.data.category}/${post.id}/`}
							class="group flex items-center gap-3 rounded-lg border border-[var(--color-border)] bg-[var(--color-surface)] p-3 no-underline transition-all hover:border-[var(--color-accent)] hover:bg-[var(--color-surface-2)]"
						>
							<span
								class="inline-flex h-8 w-8 shrink-0 items-center justify-center rounded-lg bg-[var(--color-surface-2)]"
								style={`color: ${cat.accent}`}
							>
								<CategoryIcon category={post.data.category as Category} width={16} height={16} />
							</span>
							<div class="min-w-0 flex-1">
								<h2 class="text-sm font-medium text-[var(--color-text)] truncate group-hover:text-[var(--color-accent)]">
									{pickLang(post.data.title, 'en')}
								</h2>
								<p class="text-xs text-[var(--color-text-muted)]">
									<FormattedDate date={post.data.pubDate} />
									<span class="mx-1.5">&middot;</span>
									<span style={`color: ${cat.accent}`}>{getCategoryLabel(post.data.category as Category, 'en')}</span>
								</p>
							</div>
						</a>
					);
				})}
			</div>
		</main>
		<Footer />
	</body>
</html>
